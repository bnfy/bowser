---
import BaseLayout from '../layouts/BaseLayout.astro';
import { version } from '../../../package.json';

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://blancbrowser.com/#organization',
      name: 'Blanc',
      url: 'https://blancbrowser.com/',
      logo: 'https://blancbrowser.com/logo.png',
      sameAs: [
        'https://github.com/bnfy/blanc',
        'https://www.threads.net/@blancbrowser',
        'https://www.instagram.com/blancbrowser/',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://blancbrowser.com/#website',
      url: 'https://blancbrowser.com/',
      name: 'Blanc Browser',
      alternateName: 'Blanc',
      description: 'A minimal desktop browser built around the Blanc Island.',
      publisher: {
        '@id': 'https://blancbrowser.com/#organization',
      },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://blancbrowser.com/#software',
      name: 'Blanc Browser',
      alternateName: 'Blanc',
      url: 'https://blancbrowser.com/',
      description: 'Blanc is a minimal desktop browser with search built into the Blanc Island, plus ad blocking, private tabs, slash commands, and real pages that stay in front.',
      applicationCategory: 'BrowserApplication',
      operatingSystem: 'macOS, Windows, Linux',
      softwareVersion: version,
      downloadUrl: 'https://github.com/bnfy/blanc/releases/latest',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      publisher: {
        '@id': 'https://blancbrowser.com/#organization',
      },
    },
  ],
};
---
<BaseLayout
  title="Blanc — A Minimal, Private Desktop Browser"
  description="Blanc is a minimal desktop browser with search built into one floating Island, plus ad and tracker blocking, private tabs, and keyboard-first commands for macOS, Windows, and Linux."
  path="/"
  page="home"
  header="island"
  footer="full"
  social="rich"
  ogTitle="Blanc Browser — A minimal desktop browser with built-in ad blocking"
  ogDescription="Search, tabs, and browser controls in one floating Island, with built-in ad and tracker blocking and private tabs."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(graph)} slot="head" />

<!-- ============ hero: the live island demo IS the hero ============ -->
<header class="hero">
  <svg class="mark" viewBox="0 0 149.21 199.16" aria-label="Blanc"><path fill="currentColor" d="M132.49,99.93c24.35,25.21,21.69,65.88-5.32,88.01-8.6,6.52-18.14,11.22-29.43,11.22H0S.05,0,.05,0l97.73.34c20.2.07,36.1,15.44,41.57,33.81,5.91,21.3-.72,42.38-18.13,56.78,3.89,3.02,7.96,5.58,11.27,9.01ZM123.05,76.28c11.02-13.76,12.6-31.98,4.74-47.57-6.27-10.66-16.79-19.78-29.98-19.81l-89.13-.21.04,134.11c17.74-38.18,51.53-61.94,94.24-58.73,7.99.6,14.76-1.14,20.08-7.79ZM9.18,186.44l95.77-92.67c-20.99-3.85-41.54,1.86-58.47,14.63-24.42,18.43-37.97,47.69-37.31,78.04ZM116.56,184.68c15.98-9.69,24.44-26.82,23.9-45.09s-10.27-34.19-26.36-42.19L17.5,190.42l81.36-.05c6.08,0,12.28-2.41,17.7-5.69Z"></path></svg>

  <p class="eyebrow">zero bloat <span class="k">|</span> fast focus</p>
  <div class="hero-message" id="heroMessage">
    <div class="hero-message-slide is-active" data-hero-message>
      <h1>The browser that gets out of your way.</h1>
      <p class="hero-copy">Blanc Browser is a minimal desktop browser with search built into the Blanc Island, plus ad blocking, private tabs, and slash commands.</p>
    </div>
    <div class="hero-message-slide" data-hero-message aria-hidden="true">
      <h1>Fewer ads. Less tracking. Built right in.</h1>
      <p class="hero-copy">Enjoy fewer ads and less tracking across the web, including on YouTube.</p>
    </div>
  </div>

  <div class="demo-stage" id="demoStage">
    <div class="demo-page">
      <div class="bar w1"></div>
      <div class="bar w2"></div>
      <div class="bar w3"></div>
      <div class="bar w4"></div>
    </div>
    <img class="demo-shot" id="demoShot" alt="" aria-hidden="true">
    <div class="demo-island" id="demoIsland">
      <div class="pill">
        <div class="pnav">
          <button class="pbtn" aria-label="Back"><svg viewBox="0 0 16 16"><path d="M9.75 3.5 5.25 8l4.5 4.5"/></svg></button>
          <button class="pbtn" disabled aria-label="Forward"><svg viewBox="0 0 16 16"><path d="M6.25 3.5 10.75 8l-4.5 4.5"/></svg></button>
        </div>
        <div class="dots" id="demoDots"></div>
        <span class="pill-fav" id="demoFav"></span>
        <span class="group-name" id="demoGroupName" hidden></span>
        <span class="domain" id="demoDomain"></span>
        <span class="shield" id="demoShield"></span>
        <span class="priv-chip">private <svg width="8" height="8" viewBox="0 0 12 12"><path d="M3 3 L9 9 M9 3 L3 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></span>
        <span class="psep"></span>
        <div class="pacts">
          <button class="pbtn" aria-label="Reload"><svg viewBox="0 0 16 16"><path d="M12.42 10.35a5 5 0 1 1-4.42-7.35c1.4 0 2.74.56 3.74 1.53L13 5.78"/><path d="M13 3v2.78h-2.78"/></svg></button>
          <button class="pbtn heart" id="demoHeart" aria-label="Favorite this page"><svg viewBox="0 0 16 16"><path d="M8 13.25C4.6 11 2.75 8.9 2.75 6.6a2.85 2.85 0 0 1 5.25-1.54A2.85 2.85 0 0 1 13.25 6.6c0 2.3-1.85 4.4-5.25 6.65z"/></svg></button>
        </div>
      </div>

      <div class="panel">
        <div class="panel-row">
          <div class="field"><span class="typed" id="demoTyped"></span><span class="caret"></span></div>
          <div class="pacts-row">
            <button class="abtn" disabled aria-label="Back"><svg viewBox="0 0 16 16"><path d="M9.75 3.5 5.25 8l4.5 4.5"/></svg></button>
            <button class="abtn" disabled aria-label="Forward"><svg viewBox="0 0 16 16"><path d="M6.25 3.5 10.75 8l-4.5 4.5"/></svg></button>
            <button class="abtn" aria-label="Reload"><svg viewBox="0 0 16 16"><path d="M12.42 10.35a5 5 0 1 1-4.42-7.35c1.4 0 2.74.56 3.74 1.53L13 5.78"/><path d="M13 3v2.78h-2.78"/></svg></button>
            <button class="abtn heart" aria-label="Favorite this page"><svg viewBox="0 0 16 16"><path d="M8 13.25C4.6 11 2.75 8.9 2.75 6.6a2.85 2.85 0 0 1 5.25-1.54A2.85 2.85 0 0 1 13.25 6.6c0 2.3-1.85 4.4-5.25 6.65z"/></svg></button>
            <button class="abtn" aria-label="Dismiss"><svg viewBox="0 0 16 16"><path d="M4.75 4.75l6.5 6.5M11.25 4.75l-6.5 6.5"/></svg></button>
          </div>
        </div>
        <div class="list" id="demoList"></div>
        <div class="foot-bar">
          <button class="foot-new"><svg viewBox="0 0 16 16"><path d="M8 3.25v9.5M3.25 8h9.5"/></svg><span>new tab</span><span class="foot-kbd">⌘T</span></button>
          <button class="foot-new private"><svg viewBox="0 0 16 16"><path d="M8 3.25v9.5M3.25 8h9.5"/></svg><span>private</span><span class="foot-kbd">⌘⇧N</span></button>
          <span class="foot-spacer"></span>
          <button class="foot-act" aria-label="Favorites"><svg viewBox="0 0 16 16"><path d="M8 13.25C4.6 11 2.75 8.9 2.75 6.6a2.85 2.85 0 0 1 5.25-1.54A2.85 2.85 0 0 1 13.25 6.6c0 2.3-1.85 4.4-5.25 6.65z"/></svg></button>
          <button class="foot-act" aria-label="History"><svg viewBox="0 0 16 16"><circle cx="8" cy="8" r="5.75"/><path d="M8 4.75V8l2.25 1.5"/></svg></button>
          <button class="foot-act" aria-label="Downloads"><svg viewBox="0 0 16 16"><path d="M8 2.5v6.5M5.3 6.3 8 9l2.7-2.7M3.5 12.5h9"/></svg></button>
          <button class="foot-act" aria-label="Settings"><svg viewBox="0 0 16 16"><path d="M2.5 4.75h6M12 4.75h1.5M2.5 11.25h1.5M7.5 11.25h6"/><circle cx="10.25" cy="4.75" r="1.75"/><circle cx="5.75" cy="11.25" r="1.75"/></svg></button>
        </div>
        <div class="foot" id="demoFoot">esc to dismiss · ⌘L summons · / for commands</div>
      </div>
    </div>
    <div class="demo-scrub" id="demoScrub">
      <div class="demo-scrub-track" id="demoScrubTrack">
        <div class="demo-scrub-fill" id="demoScrubFill"></div>
      </div>
    </div>
  </div>

  <p class="demo-caption" id="demoCaption"></p>

  <a class="cta" id="downloadCta" data-download-cta data-track="download_click" data-cta-position="hero" href="/download">download blanc</a>
  <p class="platforms">free · <a id="dl-mac" data-track="download_click" data-cta-position="hero-platform" href="/download">macos</a> · <a id="dl-win" data-download-link data-platform="win" data-track="download_click" data-cta-position="hero-platform" href="https://github.com/bnfy/blanc/releases/latest">windows</a> · <a id="dl-linux" data-download-link data-platform="linux" data-track="download_click" data-cta-position="hero-platform" href="https://github.com/bnfy/blanc/releases/latest">linux</a></p>
</header>

<main class="home-main">
  <section class="proof-rail" aria-label="Blanc highlights">
    <a href="/features/island" data-track="feature_cta_click" data-feature="island" data-cta-position="proof-rail">one island</a>
    <a href="/features#ad-blocking" data-track="feature_cta_click" data-feature="ad-blocking" data-cta-position="proof-rail">built-in blocking</a>
    <a href="/features/private-tabs" data-track="feature_cta_click" data-feature="private-tabs" data-cta-position="proof-rail">private tabs</a>
    <a href="/features/command-palette" data-track="feature_cta_click" data-feature="command-palette" data-cta-position="proof-rail">keyboard first</a>
  </section>

  <section class="home-intro" id="features" aria-labelledby="features-title">
    <p class="section-kicker">the browser, reduced</p>
    <h2 id="features-title">Less browser. More of what you opened it for.</h2>
    <p>Blanc keeps the everyday browser tools close without building a dashboard around them. Start with the quiet things that make a busy session feel lighter.</p>
  </section>

  <section class="home-story" id="island" aria-labelledby="island-title">
    <div class="home-story-copy">
      <p class="section-kicker">the blanc island</p>
      <h2 id="island-title">Your page gets the room.</h2>
      <p>No permanent tab strip. No toolbar taking a bite out of every page. Blanc keeps search, tabs, navigation, and page controls in one small Island—there when you need it, out of the way when you do not.</p>
      <a class="text-link" href="/features/island" data-track="feature_cta_click" data-feature="island" data-cta-position="home-story">See how the Island works <span aria-hidden="true">↗</span></a>
    </div>
    <figure class="product-capture">
      <div class="demo-stage island-figure" data-page-tone="light" role="img" aria-label="Blanc's floating Island resting over the Notion website, showing tab dots, the domain notion.so, and a shield count of one blocked item.">
        <div class="demo-page" aria-hidden="true"><div class="bar w1"></div><div class="bar w2"></div><div class="bar w3"></div><div class="bar w4"></div></div>
        <picture>
          <source media="(max-width: 560px)" srcset="/shots/mobile/notion.jpg">
          <img class="demo-shot show" src="/shots/desktop/notion.jpg" loading="lazy" alt="" aria-hidden="true">
        </picture>
        <div class="demo-island" aria-hidden="true">
          <div class="pill">
            <div class="pnav">
              <span class="pbtn"><svg viewBox="0 0 16 16"><path d="M9.75 3.5 5.25 8l4.5 4.5"/></svg></span>
              <span class="pbtn off"><svg viewBox="0 0 16 16"><path d="M6.25 3.5 10.75 8l-4.5 4.5"/></svg></span>
            </div>
            <div class="dots"><span></span><span class="cur"></span><span></span><span></span></div>
            <span class="pill-fav" style="background-image:url('/favicons/notion.so.ico')"></span>
            <span class="domain">notion.so</span>
            <span class="shield">1</span>
            <span class="psep"></span>
            <div class="pacts">
              <span class="pbtn"><svg viewBox="0 0 16 16"><path d="M12.42 10.35a5 5 0 1 1-4.42-7.35c1.4 0 2.74.56 3.74 1.53L13 5.78"/><path d="M13 3v2.78h-2.78"/></svg></span>
              <span class="pbtn heart"><svg viewBox="0 0 16 16"><path d="M8 13.25C4.6 11 2.75 8.9 2.75 6.6a2.85 2.85 0 0 1 5.25-1.54A2.85 2.85 0 0 1 13.25 6.6c0 2.3-1.85 4.4-5.25 6.65z"/></svg></span>
            </div>
          </div>
        </div>
      </div>
      <figcaption>Tabs, the current site, and the page's blocking count—without a browser bar above the page.</figcaption>
    </figure>
  </section>

  <section class="home-feature-grid" aria-label="Blanc features">
    <article class="home-feature" id="blocking">
      <p class="feature-index">01</p>
      <h2>Block the noise before it becomes a habit.</h2>
      <p>Blanc uses built-in lists to stop ads and known trackers, so you do not need to begin with an extension. The shield on the Island shows what was blocked on the page.</p>
      <a class="text-link" href="/features/ad-blocking" data-track="feature_cta_click" data-feature="ad-blocking" data-cta-position="home-feature-grid">How blocking works <span aria-hidden="true">↗</span></a>
    </article>
    <article class="home-feature" id="private-tabs">
      <p class="feature-index">02</p>
      <h2>Leave a private tab out of the record.</h2>
      <p>Private tabs stay out of Blanc history, session restore, and reopen-closed. Close the private chip when you are finished and move on.</p>
      <a class="text-link" href="/features/private-tabs" data-track="feature_cta_click" data-feature="private-tabs" data-cta-position="home-feature-grid">Read the privacy details <span aria-hidden="true">↗</span></a>
    </article>
    <article class="home-feature" id="commands">
      <p class="feature-index">03</p>
      <h2>Find the tab. Run the command. Keep moving.</h2>
      <p>Press Command or Control L and the Island blends open tabs, favorites, history, and named groups with live suggestions from your chosen search engine—or type / to run a browser command.</p>
      <a class="text-link" href="/features/command-palette" data-track="feature_cta_click" data-feature="command-palette" data-cta-position="home-feature-grid">Explore browser commands <span aria-hidden="true">↗</span></a>
    </article>
  </section>

  <section class="home-faq" aria-labelledby="faq-title">
    <div>
      <p class="section-kicker">good to know</p>
      <h2 id="faq-title">A few straight answers.</h2>
    </div>
    <div class="faq-list">
      <article>
        <h3>Is Blanc free?</h3>
        <p>Yes. A one-time supporter purchase unlocks extra app-icon colorways, but no browser features are locked behind it.</p>
      </article>
      <article>
        <h3>Does Blanc block ads?</h3>
        <p>Blanc includes ad and tracker blocking with a per-site exception. No blocker can promise to remove every ad or tracker.</p>
      </article>
      <article>
        <h3>What do private tabs do?</h3>
        <p>They keep pages out of Blanc history, session restore, and reopen-closed. They are not a separate web identity.</p>
      </article>
      <article>
        <h3>Is Blanc actually private?</h3>
        <p>Blanc blocks ads and trackers at the browser level, keeps history and favorites on your device, and sends a small pseudonymous usage ping each time it launches — you can turn it off in Settings, and the privacy policy lists every field. Optional sync — favorites, settings, and, if you choose per device, your open tabs — is end-to-end encrypted, so the server stores only data it cannot read. The <a href="/features/security">security page</a> covers the architecture; the <a href="/privacy">privacy policy</a> is the full accounting.</p>
      </article>
      <article>
        <h3>Why is there no built-in VPN?</h3>
        <p>Running a VPN means becoming a service business with your traffic in the middle — done honestly it takes audits, infrastructure, and a support organization; done halfway it is a proxy wearing a trench coat. Blanc&rsquo;s privacy work goes where the browser actually is: blocking at the network layer, sandboxing every page, and shipping no third-party extension runtime. It can also stop WebRTC from opening direct UDP paths around an application proxy, and its encrypted-DNS setting can defer DNS to your system or VPN resolver instead of choosing a browser-level provider. If you already use a VPN you trust, Blanc runs under it like any other app on your device.</p>
      </article>
      <article>
        <h3>Does Blanc have AI features?</h3>
        <p>No. There is no assistant, no sidebar copilot, no summarizer reading the page over your shoulder — and none planned as an upsell. Blanc is a browser: it renders the web, blocks the noise, and stays out of the way. Any AI you want to use is a website away; it just won&rsquo;t be bundled into the chrome.</p>
      </article>
      <article>
        <h3>Which systems does Blanc support?</h3>
        <p>Blanc is available for macOS, Windows, and Linux.</p>
      </article>
      <article>
        <h3>Who makes Blanc?</h3>
        <p>Blanc is built by <a href="https://bnfy.me" target="_blank" rel="noopener">Bananify</a>, an independent software studio — no venture funding, no investors setting the product agenda. <a href="/about">Read more about Blanc</a>.</p>
      </article>
      <article>
        <h3>Is Blanc actively developed?</h3>
        <p>Yes. Every release ships publicly on GitHub, and the <a href="/changelog">changelog</a> shows what landed most recently.</p>
      </article>
    </div>
  </section>

  <section class="home-close" aria-labelledby="close-title">
    <p class="section-kicker">ready when you are</p>
    <h2 id="close-title">A browser with less in the way.</h2>
    <p>Free for macOS, Windows, and Linux.</p>
    <a class="cta" href="/download" data-track="feature_cta_click" data-feature="home" data-cta-position="home-close">choose your download</a>
  </section>
</main>

<section class="more">
  <p class="more-line">believe in it? <a data-track="supporter_click" href="https://buy.polar.sh/polar_cl_TIxBNsxaZ7uTNG9fuCKrS1PnSQdu6ispJRgWH19Tx8p" target="_blank" rel="noopener">become a supporter</a> — $19 once, three extra icon colorways, our thanks.</p>
  <p class="more-line">custom builds — blanc&rsquo;s shell (network-level content filtering, privileged internal pages, an explicit permission policy) is available for white-label and kiosk work. <a data-track="custom_build_contact_click" href="mailto:support@blancbrowser.com">get in touch</a>.</p>
</section>

  <script src="../scripts/demo.js"></script>
</BaseLayout>
