{
  "name": "bowser",
  "productName": "Bowser",
  "version": "0.5.0",
  "description": "Minimal Electron browser shell: custom chrome UI + built-in ad/tracker blocking, no extension-store dependency.",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir",
    "release": "scripts/release.sh"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "me.bnfy.bowser",
    "productName": "Bowser",
    "publish": {
      "provider": "github",
      "owner": "bnfy",
      "repo": "bowser",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network"
    }
  }
}
