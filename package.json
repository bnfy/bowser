{
  "name": "blanc",
  "productName": "Blanc",
  "version": "0.11.0",
  "description": "Minimal Electron browser shell: custom chrome UI + built-in ad/tracker blocking, no extension-store dependency.",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir",
    "release": "scripts/release.sh",
    "test:acceptance:dry": "cucumber-js -c test/desktop/cucumber.mjs -p dry",
    "test:acceptance:desktop": "cucumber-js -c test/desktop/cucumber.mjs -p runnable",
    "tokens:build": "node tokens/build.mjs",
    "tokens:check": "node tokens/build.mjs --check"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "playwright": "^1.49.0"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "me.bnfy.bowser",
    "productName": "Blanc",
    "publish": {
      "provider": "github",
      "owner": "bnfy",
      "repo": "blanc",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "protocols": [
      {
        "name": "Web URL",
        "schemes": [
          "http",
          "https"
        ],
        "role": "Viewer"
      }
    ],
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "extendInfo": {
        "CFBundleDisplayName": "Blanc Browser",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeRole": "Viewer",
            "LSItemContentTypes": [
              "public.html"
            ]
          },
          {
            "CFBundleTypeRole": "Viewer",
            "LSItemContentTypes": [
              "public.xhtml"
            ]
          }
        ]
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network"
    }
  }
}
