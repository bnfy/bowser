{
  "$note": "Single source of truth for Blanc design tokens (substrate S2). Desktop CSS (styles.css chrome + overlay, pages.css internal pages) is guarded against drift from this file by `npm run tokens:check`; the mobile Swift/Kotlin token files in tokens/generated/ are emitted from it by `npm run tokens:build`. Edit values HERE, then run build + check. A token is themed when it has light/dark/private values; otherwise it carries a single `common` value emitted only in :root.",
  "themes": ["light", "dark", "private"],
  "consumers": {
    "chrome": "src/renderer/styles.css",
    "pages": "src/renderer/pages/pages.css"
  },
  "tokens": [
    { "name": "bg",             "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#ffffff", "dark": "#0e0e0e", "private": "#0a0a0a" } },
    { "name": "surface",        "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#f7f7f7", "dark": "#171717", "private": "#131313" } },
    { "name": "surface-raised", "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#ffffff", "dark": "#1f1f1f", "private": "#191919" } },
    { "name": "border",         "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#dedede", "dark": "#2e2e2e", "private": "#333333" } },
    { "name": "text",           "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#0e0e0e", "dark": "#f5f5f5", "private": "#f5f5f5" } },
    { "name": "text-dim",       "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#6b6b6b", "dark": "#9c9c9c", "private": "#9c9c9c" } },
    { "name": "accent",         "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#111111", "dark": "#f5f5f5", "private": "#f5f5f5" } },
    { "name": "accent-dim",     "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "rgba(17, 17, 17, 0.08)", "dark": "rgba(245, 245, 245, 0.12)", "private": "rgba(245, 245, 245, 0.12)" } },
    { "name": "danger",         "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#ff3b30", "dark": "#ff453a", "private": "#ff453a" } },
    { "name": "on-danger",      "group": "color", "consumers": ["chrome", "pages"], "values": { "light": "#ffffff", "dark": "#0e0e0e", "private": "#0a0a0a" } },

    { "name": "font-ui",        "group": "type", "consumers": ["chrome", "pages"], "values": { "common": "\"Inter\", -apple-system, \"Segoe UI Variable\", \"Segoe UI\", system-ui, sans-serif" } },
    { "name": "font-mono",      "group": "type", "consumers": ["chrome", "pages"], "values": { "common": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", \"Cascadia Code\", Menlo, Consolas, monospace" } },

    { "name": "shadow-popover", "group": "shadow", "consumers": ["chrome"], "values": { "common": "0 14px 30px rgba(14, 14, 14, 0.16)" } },
    { "name": "shadow-pill",    "group": "shadow", "consumers": ["chrome"], "values": { "common": "0 4px 12px -3px rgba(14, 14, 14, 0.22)" } },
    { "name": "strip-h",        "group": "geometry", "consumers": ["chrome"], "values": { "common": "56px" } },
    { "name": "radius",         "group": "geometry", "consumers": ["chrome", "pages"], "values": { "common": "6px" } },

    { "name": "select-caret",   "group": "asset", "consumers": ["pages"], "comment": "File, not data: URI — the pages' CSP has no img-src data: allowance, and CSS can't recolor a background image, hence one SVG per theme.", "values": { "light": "url(\"select-caret.svg\")", "dark": "url(\"select-caret-dark.svg\")", "private": "url(\"select-caret-dark.svg\")" } }
  ]
}
